<Window x:Class="PowerScope.View.UserForms.VirtualChannelSettingsWindow"
   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
   xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
   xmlns:local="clr-namespace:PowerScope.View.UserForms"
  xmlns:converters="clr-namespace:PowerScope.Converters"
mc:Ignorable="d"
    Title="Virtual Channel Settings" Height="300" Width="600"
 Background="{DynamicResource PlotSettings_BackgroundBrush}"
      Foreground="{DynamicResource PlotSettings_ButtonForegroundBrush}">
    <Window.Resources>
  <converters:ColorToBrushConverter x:Key="ColorToBrushConverter"/>
    </Window.Resources>
    <Grid Margin="20">
 <StackPanel VerticalAlignment="Top">

    <!-- Title -->
 <TextBlock Text="Virtual Channel Configuration" 
   FontSize="16" 
 FontWeight="Bold"
   Foreground="{DynamicResource PlotSettings_HeaderForegroundBrush}"
      Margin="0,0,0,15"/>

  <!-- Label Section -->
   <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,15">
   <TextBlock Text="Channel Label:" Width="100" VerticalAlignment="Center"/>
 <TextBox x:Name="LabelTextBox" 
    Width="200" 
        Padding="5"
      Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
 Background="{DynamicResource PlotSettings_TextBoxBackgroundBrush}"
   Foreground="{DynamicResource PlotSettings_ButtonForegroundBrush}"
   BorderBrush="{DynamicResource PlotSettings_BorderBrush}"/>
   </StackPanel>

        <!-- Input A Selection -->
   <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,15">
             <TextBlock Text="Input A:" Width="100" VerticalAlignment="Center"/>
    <ComboBox x:Name="InputAComboBox" 
      Width="200"
  Padding="5"
Background="{DynamicResource PlotSettings_TextBoxBackgroundBrush}"
       Foreground="{DynamicResource PlotSettings_ButtonForegroundBrush}"
 BorderBrush="{DynamicResource PlotSettings_BorderBrush}"
ItemsSource="{Binding AvailableChannels}">
            <ComboBox.ItemTemplate>
             <DataTemplate>
                 <StackPanel Orientation="Horizontal">
          <Rectangle Width="12" Height="12" Margin="0,0,8,0" 
       Fill="{Binding Color, Converter={StaticResource ColorToBrushConverter}}"/>
    <TextBlock Text="{Binding Label}" VerticalAlignment="Center"/>
      </StackPanel>
       </DataTemplate>
            </ComboBox.ItemTemplate>
</ComboBox>
   </StackPanel>

        <!-- Operation Selection -->
   <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,15">
     <TextBlock Text="Operation:" Width="100" VerticalAlignment="Center"/>
<ComboBox x:Name="OperationComboBox" 
  Width="200"
   Padding="5"
   Background="{DynamicResource PlotSettings_TextBoxBackgroundBrush}"
      Foreground="{DynamicResource PlotSettings_ButtonForegroundBrush}"
     BorderBrush="{DynamicResource PlotSettings_BorderBrush}">
     <ComboBoxItem Content="Add"/>
<ComboBoxItem Content="Subtract"/>
 <ComboBoxItem Content="Multiply"/>
           <ComboBoxItem Content="Divide"/>
        </ComboBox>
    </StackPanel>

  <!-- Input B Selection -->
   <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,15">
         <TextBlock Text="Input B:" Width="100" VerticalAlignment="Center"/>
    <ComboBox x:Name="InputBComboBox" 
      Width="200"
Padding="5"
    Background="{DynamicResource PlotSettings_TextBoxBackgroundBrush}"
 Foreground="{DynamicResource PlotSettings_ButtonForegroundBrush}"
    BorderBrush="{DynamicResource PlotSettings_BorderBrush}"
ItemsSource="{Binding AvailableChannels}">
            <ComboBox.ItemTemplate>
       <DataTemplate>
     <StackPanel Orientation="Horizontal">
  <Rectangle Width="12" Height="12" Margin="0,0,8,0" 
           Fill="{Binding Color, Converter={StaticResource ColorToBrushConverter}}"/>
       <TextBlock Text="{Binding Label}" VerticalAlignment="Center"/>
     </StackPanel>
</DataTemplate>
            </ComboBox.ItemTemplate>
         </ComboBox>
     </StackPanel>

      <!-- Buttons Section -->
       <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
 <Button x:Name="ApplyButton" 
      Content="Apply" 
Width="80"
   Padding="10,5"
     Margin="0,0,10,0"
    Click="ApplyButton_Click"
        Background="{DynamicResource PlotSettings_TitleBarBrush}"
      Foreground="{DynamicResource PlotSettings_ButtonForegroundBrush}"
         BorderBrush="{DynamicResource PlotSettings_BorderBrush}"/>
      <Button x:Name="CancelButton" 
 Content="Cancel" 
Width="80"
         Padding="10,5"
      Click="CancelButton_Click"
 Background="{DynamicResource PlotSettings_TitleBarBrush}"
 Foreground="{DynamicResource PlotSettings_ButtonForegroundBrush}"
 BorderBrush="{DynamicResource PlotSettings_BorderBrush}"/>
       </StackPanel>
    </StackPanel>
    </Grid>
</Window>
